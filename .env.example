# CONFIGURACIÓN DE BASE DE DATOS - WorkManager ERP v2.0
# Copie este archivo como .env y configure sus valores

# Entorno de aplicación (local, production, testing)
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Configuración de Base de Datos
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=workmanager_erp
DB_USERNAME=root
DB_PASSWORD=

# Configuración de Sesión
SESSION_LIFETIME=120
SESSION_SECURE=false

# Configuración de Seguridad
APP_KEY=base64:your-secret-key-here
JWT_SECRET=your-jwt-secret-here

# Configuración de Email (opcional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# Configuración de Cache (opcional)
CACHE_DRIVER=file
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Configuración de Logs
LOG_LEVEL=info
LOG_CHANNEL=daily

# APIs Externas (opcional)
GOOGLE_MAPS_API_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
