RewriteEngine On
Options -Indexes

# Los datos persistentes nunca se sirven directamente.
RewriteRule ^data/(?!agente_navissi\.ps1$|reportar_problema\.ps1$|desplegar_en_pc_empleado\.ps1$) - [F,L,NC]
RewriteRule (^|/)\.(?!well-known/) - [F,L]
<FilesMatch "(?i)\.(sqlite|db|json|log|env|ini|bak|sql|key)$">
    Require all denied
</FilesMatch>

# Cualquier .php inexistente da 404 real, en vez de caer silenciosamente al
# dashboard (como hacia el catch-all anterior) - un enlace roto o un archivo
# que no llego bien en un deploy debe notarse de inmediato, no parecer que
# "abre otro modulo".
RewriteCond %{REQUEST_URI} \.php$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ - [R=404,L]
